<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.CategoryMapper">
    <!--模糊查询所有-->
    <select id="selectAll" resultType="com.example.entity.Category">
        select *
        from category
        <where>
            <if test="name != null and name != '' ">and name like concat('%',#{name}, '%')</if>
        </where>
        order by id
    </select>
    <!--新增数据-->
    <insert id="insert" parameterType="com.example.entity.Category">
        insert into category(name)
        values (#{name})
    </insert>
    <!--修改数据-->
    <update id="updateById" parameterType="com.example.entity.Category">
        update category
        set name = #{name}
        where id = #{id}
    </update>
    <!--根据id删除-->
    <delete id="deleteById" parameterType="com.example.entity.Category">
        delete
        from category
        where id = #{id}
    </delete>
</mapper>
